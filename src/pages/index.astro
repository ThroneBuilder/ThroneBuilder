---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, TAG_VALUES } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---
<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonicalUrl={SITE_URL + '/'}
>
  <div class="page-wrapper">
    <header class="site-header">
      <h1>{SITE_TITLE}</h1>
      <p class="tagline">{SITE_DESCRIPTION}</p>
    </header>

    <nav class="filter-bar js-only" aria-label="Filter articles by tag">
      <button class="filter-btn" data-filter="all" aria-pressed="true">All</button>
      {TAG_VALUES.map((tag) => (
        <button class="filter-btn" data-filter={tag} aria-pressed="false">{tag}</button>
      ))}
    </nav>

    <section aria-label="Articles" id="article-list">
      {posts.length === 0 && (
        <p class="empty">No articles yet. Check back soon.</p>
      )}
      {posts.map((post) => (
        <article
          class="post-card"
          data-tags={post.data.tags.join(',')}
        >
          <h2>
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
          {post.data.tags.length > 0 && (
            <div class="tag-list">
              {post.data.tags.map((tag) => (
                <span class="tag-badge">{tag}</span>
              ))}
            </div>
          )}
          <p>{post.data.description}</p>
        </article>
      ))}
      <p class="empty filter-empty" aria-live="polite" hidden>No articles match this filter.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    max-width: var(--max-width-content);
    margin: 0 auto;
    padding: 0 var(--spacing-4);
  }

  .site-header {
    padding: var(--spacing-12) 0 var(--spacing-8);
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--spacing-8);
  }

  .site-header h1 {
    font-size: var(--font-size-3xl);
    line-height: var(--line-height-heading);
    margin-bottom: var(--spacing-2);
  }

  .tagline {
    color: var(--color-muted);
    font-size: var(--font-size-lg);
  }

  .post-card {
    padding: var(--spacing-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card h2 {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-heading);
    margin-bottom: var(--spacing-1);
  }

  .post-card h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card h2 a:hover,
  .post-card h2 a:focus {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-card h2 a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  time {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin-bottom: var(--spacing-2);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
    margin: var(--spacing-1) 0 var(--spacing-2);
  }

  .empty {
    color: var(--color-muted);
    padding: var(--spacing-8) 0;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const articles = document.querySelectorAll<HTMLElement>('#article-list article');
  const emptyMsg = document.querySelector<HTMLElement>('.filter-empty');

  function applyFilter(filter: string) {
    let visible = 0;

    articles.forEach((article) => {
      const tags = article.dataset.tags ? article.dataset.tags.split(',') : [];
      const show = filter === 'all' || tags.includes(filter);
      article.hidden = !show;
      if (show) visible++;
    });

    buttons.forEach((btn) => {
      btn.setAttribute('aria-pressed', btn.dataset.filter === filter ? 'true' : 'false');
    });

    if (emptyMsg) {
      emptyMsg.hidden = visible > 0;
    }
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.filter ?? 'all');
    });
  });
</script>
