---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, TAG_VALUES } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

function ytThumbnail(url: string | undefined): string | undefined {
  if (!url) return undefined;
  const m = url.match(/(?:youtu\.be\/|[?&]v=)([A-Za-z0-9_-]{11})/);
  return m ? `https://img.youtube.com/vi/${m[1]}/hqdefault.jpg` : undefined;
}

type Variant = 'featured' | 'standard' | 'text';
const postsWithVariants = posts.map((post, index) => {
  const effectiveCover = post.data.coverImage ?? ytThumbnail(post.data.youtubeUrl);
  const variant: Variant = index === 0 && effectiveCover
    ? 'featured'
    : effectiveCover
    ? 'standard'
    : 'text';
  return { post, variant, effectiveCover };
});
---
<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonicalUrl={SITE_URL + '/'}
>
  <div class="page-wrapper">
    <header class="site-header">
      <h1>{SITE_TITLE}</h1>
      <p class="tagline">{SITE_DESCRIPTION}</p>
    </header>

    <nav class="filter-bar js-only" aria-label="Filter articles by tag">
      <button class="filter-btn" data-filter="all" aria-pressed="true">All</button>
      {TAG_VALUES.map((tag) => (
        <button class="filter-btn" data-filter={tag} aria-pressed="false">{tag}</button>
      ))}
    </nav>

    <section aria-label="Articles" id="article-list">
      {posts.length === 0 && (
        <p class="empty">No articles yet. Check back soon.</p>
      )}
      <div class="article-grid">
        {postsWithVariants.map(({ post, variant, effectiveCover }) => (
          <article
            class={`post-card post-card--${variant}`}
            data-tags={post.data.tags.join(',')}
          >
            {variant === 'featured' && effectiveCover && (
              <img
                src={effectiveCover}
                alt=""
                loading="eager"
                fetchpriority="high"
                width="1440"
                height="600"
              />
            )}
            {variant === 'standard' && effectiveCover && (
              <img
                src={effectiveCover}
                alt=""
                loading="lazy"
                width="800"
                height="450"
              />
            )}
            <div class={variant === 'featured' ? 'post-card__overlay' : 'post-card__body'}>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2>
                <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h2>
              {post.data.tags.length > 0 && (
                <div class="tag-list">
                  {post.data.tags.map((tag) => (
                    <span class="tag-badge">{tag}</span>
                  ))}
                </div>
              )}
              <p>{post.data.description}</p>
            </div>
          </article>
        ))}
      </div>
      <p class="empty filter-empty" aria-live="polite" hidden>No articles match this filter.</p>
    </section>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 var(--spacing-4);
  }

  /* ---- Site header ---- */
  .site-header {
    padding: var(--spacing-12) 0 var(--spacing-8);
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--spacing-8);
  }

  .site-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: var(--line-height-heading);
    margin-bottom: var(--spacing-2);
  }

  .tagline {
    color: var(--color-muted);
    font-size: var(--font-size-lg);
  }

  /* ---- Magazine grid ---- */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1.5rem;
    margin-bottom: var(--spacing-4);
  }

  /* ---- Featured card (first article with cover image, full width) ---- */
  .post-card--featured {
    grid-column: 1 / -1;
    position: relative;
  }

  .post-card--featured img {
    width: 100%;
    aspect-ratio: 16 / 7;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .post-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.72));
    color: #fff;
  }

  .post-card__overlay time {
    display: block;
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: var(--spacing-1);
  }

  .post-card__overlay h2 {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-heading);
    margin-bottom: var(--spacing-1);
  }

  .post-card__overlay h2 a {
    color: #fff;
    text-decoration: none;
  }

  .post-card__overlay h2 a:hover,
  .post-card__overlay h2 a:focus {
    text-decoration: underline;
  }

  .post-card__overlay h2 a:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.8);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .post-card__overlay .tag-badge {
    background-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.9);
  }

  /* ---- Standard + text cards (3-up grid) ---- */
  .post-card--standard,
  .post-card--text {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
  }

  .post-card--standard img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    margin-bottom: var(--spacing-2);
  }

  .post-card__body {
    flex: 1;
    padding-bottom: var(--spacing-4);
    border-bottom: 1px solid var(--color-border);
  }

  .post-card__body time {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin-bottom: var(--spacing-1);
  }

  .post-card__body h2 {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-heading);
    margin-bottom: var(--spacing-1);
  }

  .post-card__body h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card__body h2 a:hover,
  .post-card__body h2 a:focus {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-card__body h2 a:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .post-card__body p {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin-top: var(--spacing-2);
    line-height: 1.5;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-1);
    margin: var(--spacing-1) 0 var(--spacing-2);
  }

  .empty {
    color: var(--color-muted);
    padding: var(--spacing-8) 0;
  }

  /* ---- Responsive breakpoints ---- */
  @media (max-width: 768px) {
    .post-card--standard,
    .post-card--text {
      grid-column: span 6;
    }

    .post-card--featured img {
      aspect-ratio: 16 / 9;
    }
  }

  @media (max-width: 480px) {
    .post-card--standard,
    .post-card--text {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const articles = document.querySelectorAll<HTMLElement>('#article-list article');
  const emptyMsg = document.querySelector<HTMLElement>('.filter-empty');

  function applyFilter(filter: string) {
    let visible = 0;

    articles.forEach((article) => {
      const tags = article.dataset.tags ? article.dataset.tags.split(',') : [];
      const show = filter === 'all' || tags.includes(filter);
      article.hidden = !show;
      if (show) visible++;
    });

    buttons.forEach((btn) => {
      btn.setAttribute('aria-pressed', btn.dataset.filter === filter ? 'true' : 'false');
    });

    if (emptyMsg) {
      emptyMsg.hidden = visible > 0;
    }
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      applyFilter(btn.dataset.filter ?? 'all');
    });
  });
</script>
